datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  RETIRADA
  ENTREGA
}

enum BudgetType {
  BORDADO
  CONSERTO_ROUPA
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  phone        String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addresses    Address[]
  orders       Order[]
}

model Address {
  id           String   @id @default(uuid())
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  distanceKm   Float    @default(0.0)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String
  category    String      // "papelaria" or "miscelaneas"
  stock       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  total        Float
  status       OrderStatus  @default(PENDING)
  deliveryType DeliveryType @default(RETIRADA)
  deliveryFee  Float        @default(0.0)
  distanceKm   Float        @default(0.0)
  addressId    String?
  address      Address?     @relation(fields: [addressId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model BudgetRequest {
  id          String     @id @default(uuid())
  type        BudgetType
  name        String
  phone       String
  description String
  fileUrl     String
  emailSent   Boolean    @default(false)
  status      String     @default("PENDING") // "PENDING", "COMPLETED"
  createdAt   DateTime   @default(now())
}
